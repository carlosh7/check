# Puerto del servidor
PORT=3000

# Clave JWT (generar con: openssl rand -hex 32 en Linux/Mac, o usar https://acte.ltd/utils/randomkeygen)
JWT_SECRET=tu_clave_aqui_cambiar_en_produccion

# Base de datos (para futuro PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=check_production
DB_USER=check_user
DB_PASSWORD=tu_password_aqui

# SMTP (para envío de emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu_password_app
SMTP_SECURE=false

# URL de la aplicación
APP_URL=http://localhost:3000

# Admin inicial (cambiar después de instalar)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Dominios permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://tudominio.com
