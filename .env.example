# Puertos
PORT=3000

# JWT (generar con: openssl rand -hex 32)
JWT_SECRET=genera_una_clave_unica

# Cifrado AES-256-GCM para passwords SMTP/IMAP (generar con: openssl rand -hex 32)
# Si no se configura, las passwords se guardan en texto plano
# ENCRYPTION_KEY=genera_una_clave_unica_de_64_caracteres_hex

# URL de la aplicación
APP_URL=http://localhost:3000

# Admin inicial
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://tudominio.com

# Web Push API (VAPID)
# Generar: node -e "const webpush = require('web-push'); const k = webpush.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY=' + k.publicKey); console.log('VAPID_PRIVATE_KEY=' + k.privateKey);"
VAPID_PUBLIC_KEY=tu_clave_publica_aqui
VAPID_PRIVATE_KEY=tu_clave_privada_aqui
VAPID_SUBJECT=mailto:admin@check.com

# Auto-deploy (C6-14)
# DEPLOY_WEBHOOK_SECRET=openssl_rand_-hex_32
# PORTAINER_WEBHOOK_URL=https://tu-portainer:9443/api/stacks/webhooks/ID
