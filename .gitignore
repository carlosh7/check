# ============================================
# Check Pro - .gitignore
# ============================================

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/

# --- Base de datos SQLite ---
check_app.db
check_app.db-journal
check_app.db-shm
check_app.db-wal
data/*.db
data/*.db-*

# --- Variables de entorno ---
.env
.env.local
.env.*.local

# --- Uploads y archivos generados ---
uploads/
*.xlsx
*.xls
*.csv

# --- Logs ---
*.log
logs/
server.log

# --- IDEs y editores ---
.vscode/
*.code-workspace
.history/
.idea/

# --- OS ---
.DS_Store
Thumbs.db
$RECYCLE.BIN/
*.lnk
[Dd]esktop.ini

# --- Windows reserved names ---
nul
con
prn
aux

# --- Backups ---
*.backup
*.bak
*-backup.*
*.old
*.tmp
*.temp

# --- Capturas de pantalla ---
.Capturas/
*.png
*.jpg
*.jpeg
*.gif
*.bmp
!public/assets/

# --- Docker ---
docker-compose.override.yml

# --- OpenCode/Agent ---
.opencode-config.md
.opencode-skill.md
.agent/

# --- Build output ---
dist/
build/
data/
*.pdf
