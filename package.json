  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');if(!fs.existsSync('.env')){fs.copyFileSync('.env.example','.env');console.log('.env created');}else{console.log('.env already exists');}if(!fs.existsSync('data')){fs.mkdirSync('data');console.log('data folder created');}else{console.log('data folder already exists');}\"",
    "setup": "node setup.js",
    "start": "node server.js",
    "dev": "node setup.js",
    "build:css": "npx postcss src/styles/main.css -o public/css/styles.css",
    "watch:css": "npx postcss src/styles/main.css -o public/css/styles.css --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
